<!DOCTYPE html>
<html>
<head>
    <title>Skincare Advertisement</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #fdf6f0;
            text-align: center;
        }

        .ad {
            width: 350px;
            margin: 100px auto;
            padding: 20px;
            background-color: #ffe4e1;
            border-radius: 10px;
            box-shadow: 2px 2px 10px gray;
        }

        h1 {
            color: #d63384;
        }

        button {
            background-color: #d63384;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 5px;
            cursor: pointer;
        }

        button:hover {
            background-color: #b0256d;
        }
    </style>
</head>
<body>

    <div class="ad">
        <h1>GlowCare Skincare</h1>
        <p>Get healthy, glowing skin naturally!</p>
        <p>Special Offer: 20% OFF on all products.</p>
        <button>Shop Now</button>
    </div>

</body>
</html>
